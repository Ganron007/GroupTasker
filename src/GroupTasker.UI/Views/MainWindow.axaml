<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupTasker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="GroupTasker.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Title="{Binding TitleWithVersion}"
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        Background="#1A1A1A"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/grouptasker.ico">

    <!-- No Design.DataContext: MainWindowViewModel's ctor requires services and would
         throw at design-time when the previewer tries to instantiate it parameterlessly. -->

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D0D0D" Padding="32,24">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GroupTasker"
                               FontSize="28" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                    <Border Background="#252525"
                            CornerRadius="10"
                            Padding="8,3"
                            Margin="12,4,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding VersionLabel}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#9F9F9F" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Group your favourite programs and pin them to the taskbar for easy access"
                           FontSize="13"
                           Foreground="#8F8F8F"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Group Cards Grid -->
        <ScrollViewer Grid.Row="1" Margin="32,24">
            <StackPanel>


                <!-- Groups Grid -->
                <WrapPanel>
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:GroupCardViewModel">
                                <Border Background="#252525" CornerRadius="8"
                                        Padding="20" Margin="0,0,16,16"
                                        Width="260" Cursor="Hand"
                                        Classes="Card">
                                    <StackPanel>
                                        <!-- Group Icon -->
                                        <Border Background="#373737" CornerRadius="6"
                                                Width="56" Height="56"
                                                HorizontalAlignment="Center">
                                            <Image Source="{Binding Icon}"
                                                   Width="48" Height="48"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Group Name -->
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,12,0,4" />

                                        <!-- Shortcut Count -->
                                        <TextBlock Text="{Binding ShortcutCount, StringFormat={}{0} shortcuts}"
                                                   FontSize="12"
                                                   Foreground="#8F8F8F"
                                                   HorizontalAlignment="Center" />

                                        <!-- Action Buttons -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,16,0,0"
                                                    Spacing="8">
                                            <Button Content="Pin"
                                                    Command="{Binding $parent[Window].DataContext.PinToTaskbarCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="Primary" />
                                            <Button Content="Edit"
                                                    Command="{Binding $parent[Window].DataContext.EditGroupCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="Secondary" />
                                            <Button Content="Delete"
                                                    Command="{Binding $parent[Window].DataContext.DeleteGroupCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="Danger" />
                                        </StackPanel>

                                        <!-- Pin Status -->
                                        <TextBlock Text="{Binding PinStatus}"
                                                   FontSize="11"
                                                   Foreground="#6FAF6F"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="#0D0D0D" Padding="32,16">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Button Grid.Column="0" Content="+ Add Group"
                        Command="{Binding AddGroupCommand}"
                        Classes="Primary"
                        HorizontalAlignment="Left" />
                <Button Grid.Column="1" Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        Classes="Secondary"
                        AutomationProperties.Name="Open settings (global hotkey, primary group)"
                        Margin="0,0,12,0" />
            </Grid>
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#5A5A5A" />
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8F8F8F" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CC4444" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="#3A2222" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="#331111" />
        </Style>
        <Style Selector="Border.Card:pointerover">
            <Setter Property="Background" Value="#2E2E2E" />
        </Style>
    </Window.Styles>
</Window>
