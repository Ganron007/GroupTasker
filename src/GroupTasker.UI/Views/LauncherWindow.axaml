<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupTasker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="308" d:DesignHeight="140"
        x:Class="GroupTasker.UI.Views.LauncherWindow"
        x:DataType="vm:LauncherViewModel"
        Title="{Binding Title}"
        Width="320" MinHeight="56" MaxHeight="500"
        SizeToContent="Height"
        Background="Transparent"
        WindowStartupLocation="Manual"
        CanResize="False"
         WindowDecorations="None"
         Topmost="True"
        TransparencyLevelHint="None">

    <!-- No Design.DataContext: ctor requires services; designer cannot instantiate it parameterlessly. -->

    <Border Background="#1A1A1A"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="6">
        <Grid RowDefinitions="6,*">

            <!-- Invisible drag strip — 6px at top, cursor changes on hover -->
            <Rectangle Grid.Row="0" Fill="Transparent"
                       Cursor="Hand"
                       PointerPressed="OnDragStripPressed" />

             <!-- Shortcut grid — 7 columns, 44×44 cells, exact fit (320-2-10=308 = 7×44) -->
             <ScrollViewer Grid.Row="1" Padding="5,4"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Shortcuts}"
                              Name="ShortcutsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LauncherShortcutViewModel">
                            <Border Width="40" Height="40" Margin="2"
                                    Opacity="{Binding IconOpacity}"
                                    Cursor="Hand"
                                    ToolTip.Tip="{Binding TooltipText}"
                                    Classes="ShortcutIcon"
                                    PointerPressed="OnShortcutPressed"
                                    PointerMoved="OnShortcutMoved"
                                    PointerReleased="OnShortcutReleased">
                                <Image Source="{Binding Icon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Border.ShortcutIcon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ShortcutIcon:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
    </Window.Styles>
</Window>
