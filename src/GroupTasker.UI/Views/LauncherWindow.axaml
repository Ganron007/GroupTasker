<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupTasker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="308" d:DesignHeight="140"
        x:Class="GroupTasker.UI.Views.LauncherWindow"
        x:DataType="vm:LauncherViewModel"
        Title="{Binding Title}"
        Width="320" MinHeight="56" MaxHeight="500"
        SizeToContent="Height"
        Background="Transparent"
        WindowStartupLocation="Manual"
        CanResize="False"
         WindowDecorations="None"
         Topmost="True"
        TransparencyLevelHint="None">

    <!-- No Design.DataContext: ctor requires services; designer cannot instantiate it parameterlessly. -->

    <Border Background="#1A1A1A"
            BorderBrush="{Binding AccentColor}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid RowDefinitions="6,Auto,*">

            <!-- Invisible drag strip — 6px at top, cursor changes on hover -->
            <Rectangle Grid.Row="0" Fill="Transparent"
                       Cursor="Hand"
                       PointerPressed="OnDragStripPressed" />

            <!-- Filter box -->
            <TextBox Grid.Row="1" Name="FilterTextBox"
                     Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Filter…"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8,4"
                     FontSize="12"
                     AutomationProperties.Name="Filter shortcuts"
                     KeyDown="OnFilterKeyDown" />

             <!-- Shortcut grid — 7 columns, 44×44 cells, exact fit (320-2-10=308 = 7×44) -->
             <ScrollViewer Grid.Row="2" Padding="5,4"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Shortcuts}"
                              Name="ShortcutsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LauncherShortcutViewModel">
                            <Border Width="40" Height="40" Margin="2"
                                    Opacity="{Binding IconOpacity}"
                                    Cursor="Hand"
                                    Focusable="True"
                                    AutomationProperties.Name="{Binding TooltipText}"
                                    ToolTip.Tip="{Binding TooltipText}"
                                    Classes="ShortcutIcon"
                                    PointerPressed="OnShortcutPressed"
                                    PointerMoved="OnShortcutMoved"
                                PointerReleased="OnShortcutReleased">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open file location"
                                                  Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).OpenFileLocationCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Edit shortcut"
                                                  Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).EditShortcutCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Copy path"
                                                  Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).CopyPathCommand}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Properties"
                                                  Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).ShowPropertiesCommand}"
                                                  CommandParameter="{Binding}" />
                                        <Separator />
                                        <MenuItem Header="Remove from group"
                                                  Command="{Binding $parent[ItemsControl].((vm:LauncherViewModel)DataContext).RemoveFromGroupCommand}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Image Source="{Binding Icon}"
                                       Width="32" Height="32"
                                       Stretch="Uniform" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Border.ShortcutIcon">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ShortcutIcon:pointerover">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
        <Style Selector="Border.ShortcutIcon:focus">
            <Setter Property="BorderBrush" Value="#4A9EFF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="TextBox#FilterTextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#4A9EFF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ContextMenu MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <Style Selector="ContextMenu MenuItem:pointerover">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
    </Window.Styles>
</Window>
