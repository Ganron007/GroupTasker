<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupTasker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
        x:Class="GroupTasker.UI.Views.SettingsDialog"
        x:DataType="vm:SettingsViewModel"
        Title="Settings — GroupTasker"
        Width="500" Height="420"
        MinWidth="400" MinHeight="320"
        Background="#1A1A1A"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <StackPanel Grid.Row="0" Spacing="20">

            <!-- Primary group selector -->
            <StackPanel Spacing="6">
                <TextBlock Text="Primary group"
                           FontSize="12" Foreground="#8F8F8F" />
                <ComboBox ItemsSource="{Binding AvailableGroups}"
                          SelectedValue="{Binding PrimaryGroupId}"
                          SelectedValueBinding="{Binding Id}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="(None — use the first group)"
                          FontSize="14" Foreground="White"
                          Background="#252525" />
                <TextBlock Text="The group that opens when you press the global hotkey."
                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Hotkey input -->
            <StackPanel Spacing="6">
                <TextBlock Text="Global hotkey"
                           FontSize="12" Foreground="#8F8F8F" />
                <TextBox Text="{Binding HotkeyText}"
                         FontSize="14" Foreground="White"
                         Background="#252525" BorderBrush="#3A3A3A"
                         BorderThickness="1" CornerRadius="6"
                         Padding="12,8"
                         PlaceholderText="e.g. Ctrl+Alt+G (leave empty to disable)" />
                <TextBlock Text="Format: one or more modifiers (Ctrl, Alt, Shift, Win) + one key. Examples: Ctrl+Alt+G, Alt+F4, Ctrl+Shift+F12."
                           FontSize="11" Foreground="#6A6A6A" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Error / status -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="12" Foreground="#FF6666"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Foreground="#6FAF6F"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0" Spacing="12">
            <Button Content="Close" Click="OnCloseClicked" Classes="Secondary" />
            <Button Content="Save" Command="{Binding SaveCommand}" Classes="Primary" />
        </StackPanel>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#5A5A5A" />
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8F8F8F" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>
</Window>
