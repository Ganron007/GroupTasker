<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GroupTasker.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="500"
        x:Class="GroupTasker.UI.Views.AppPickerDialog"
        x:DataType="vm:AppPickerViewModel"
        Title="Add from running apps — GroupTasker"
        Width="520" Height="500"
        MinWidth="400" MinHeight="350"
        Background="#1A1A1A"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Pick a running app or pinned taskbar item"
                       FontSize="14" Foreground="White" FontWeight="SemiBold" />
            <TextBlock Text="Live apps are launched by process name or AUMI, so they survive app updates."
                       FontSize="11" Foreground="#8F8F8F" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Search filter -->
        <TextBox Grid.Row="1"
                 Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Filter by name or process…"
                 FontSize="13" Foreground="White"
                 Background="#252525"
                 BorderBrush="#3A3A3A"
                 BorderThickness="1"
                 CornerRadius="4"
                 Padding="10,8"
                 Margin="0,0,0,12" />

        <!-- App list -->
        <Border Grid.Row="2" Background="#202020" CornerRadius="4" Padding="4">
            <ListBox ItemsSource="{Binding Apps}"
                     SelectedItem="{Binding SelectedApp, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiscoveredAppViewModel">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="6,4">
                            <TextBlock Grid.Column="0" Text="{Binding SourceLabel}"
                                       FontSize="11" Foreground="#5A8FCC"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ExecutablePath}"
                                           FontSize="10" Foreground="#6A6A6A" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding ProcessName}"
                                       FontSize="10" Foreground="#5A5A5A"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0" Spacing="12">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="Secondary" />
            <Button Content="Add" Command="{Binding AddCommand}" Classes="Primary"
                    IsEnabled="{Binding SelectedApp, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#5A5A5A" />
        </Style>
        <Style Selector="Button.Primary:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8F8F8F" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>
</Window>
